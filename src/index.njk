<!-- Latest Blog Posts Section -->
{% set latestPosts = collections.blog | limit(3) %}
{% if latestPosts.length > 0 %}
<section class="section section-gray">
  <div class="container">
    <div class="section-header">
      <span class="section-label">From Our Blog</span>
      <h2 class="section-title">Latest IT & Security Insights</h2>
      <p class="section-subtitle">Expert advice on protecting your business, optimizing your technology, and staying ahead of cyber threats.</p>
    </div>
    
    <div class="home-blog-grid">
      {% for post in latestPosts %}
      <article class="blog-card">
        {% if post.data.featuredImage %}
        <a href="{{ post.url }}" class="blog-card-image">
          <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}">
        </a>
        {% endif %}
        <div class="blog-card-content">
          {% if post.data.tags %}
          <div class="blog-card-tags">
            {% for tag in post.data.tags %}
            {% if tag != "post" %}
            <span class="blog-tag">{{ tag }}</span>
            {% endif %}
            {% endfor %}
          </div>
          {% endif %}
          <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
          <p>{{ post.data.excerpt }}</p>
          <div class="blog-card-meta">
            <span>{{ post.data.date | dateFormat }}</span>
            {% if post.data.readTime %}
            <span>{{ post.data.readTime }} min read</span>
            {% endif %}
          </div>
        </div>
      </article>
      {% endfor %}
    </div>
    
    <div style="text-align: center; margin-top: 2.5rem;">
      <a href="/blog/" class="btn btn-outline">
        View All Articles
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
    </div>
  </div>
</section>
{% endif %}

