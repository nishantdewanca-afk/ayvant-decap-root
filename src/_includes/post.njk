---
layout: base.njk
---
<article class="blog-post">
  <!-- Hero Section -->
  <section class="blog-post-hero">
    <div class="container" style="max-width: 56rem;">
      <div class="blog-post-meta">
        <a href="/blog/" class="blog-post-back">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          Back to Blog
        </a>
        {% if tags %}
        <div class="blog-post-tags">
          {% for tag in tags %}
          {% if tag != "post" %}
          <span class="blog-tag">{{ tag }}</span>
          {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
      <h1>{{ title }}</h1>
      <div class="blog-post-info">
        <span class="blog-post-author">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          {{ author or "Ayvant Team" }}
        </span>
        <span class="blog-post-date">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          {{ date | dateFormat }}
        </span>
        {% if readTime %}
        <span class="blog-post-read">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          {{ readTime }} min read
        </span>
        {% endif %}
      </div>
    </div>
  </section>

  {% if featuredImage %}
  <div class="blog-post-image">
    <div class="container" style="max-width: 56rem;">
      <img src="{{ featuredImage }}" alt="{{ title }}">
    </div>
  </div>
  {% endif %}

  <!-- Content -->
  <section class="blog-post-content">
    <div class="container" style="max-width: 56rem;">
      {{ content | safe }}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section section-red">
    <div class="container text-center">
      <h2 class="section-title">Need Help With Your IT Security?</h2>
      <p class="section-subtitle" style="margin-bottom: 2rem;">Let's have a conversation about your IT needs. No pressure, no jargon – just honest advice from people who care about your business.</p>
      <div class="hero-buttons" style="justify-content: center;">
        <a href="/pages/contact/" class="btn btn-white btn-lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
          Get a Free Assessment
        </a>
        <a href="tel:+16042392090" class="btn btn-outline btn-lg">Call {{ site.phone }}</a>
      </div>
    </div>
  </section>
</article>
