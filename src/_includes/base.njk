<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ metaTitle or title }} | {{ site.name }}</title>
  <meta name="description" content="{{ metaDescription or description or site.description }}">
  
  <!-- Preconnect to required origins -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://images.unsplash.com">
  
  <!-- Google Fonts - Loaded async to prevent render blocking -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Chivo:wght@400;700;900&family=Manrope:wght@400;500;600;700&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Chivo:wght@400;700;900&family=Manrope:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Chivo:wght@400;700;900&family=Manrope:wght@400;500;600;700&display=swap"></noscript>
  
  
  <!-- Main CSS -->
  <link rel="stylesheet" href="/css/style.css">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  
  <!-- Open Graph -->
  <meta property="og:title" content="{{ metaTitle or title }} | {{ site.name }}">
  <meta property="og:description" content="{{ metaDescription or description or site.description }}">
  <meta property="og:type" content="{{ 'article' if layout == 'post' else 'website' }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  {% if featuredImage %}
  <meta property="og:image" content="{{ site.url }}{{ featuredImage }}">
  {% endif %}
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ metaTitle or title }} | {{ site.name }}">
  <meta name="twitter:description" content="{{ metaDescription or description or site.description }}">
</head>
<body>
  {% include "header.njk" %}
  
  <main>
    {{ content | safe }}
  </main>
  
  {% include "footer.njk" %}
  
  <!-- Cookie Banner -->
  <div class="cookie-banner" id="cookie-banner">
    <div class="container cookie-banner-inner">
      <p>We use cookies to enhance your browsing experience and analyze site traffic. By clicking "OK", you consent to our use of cookies. <a href="/pages/cookie-policy/">Learn more</a></p>
      <button class="btn btn-primary" id="cookie-accept">OK</button>
    </div>
  </div>

  <!-- Exit Intent Popup -->
  <div class="exit-popup-overlay" id="exit-popup">
    <div class="exit-popup">
      <button class="exit-popup-close" id="exit-popup-close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <div class="exit-popup-header">
        <p>Wait! Before You Go...</p>
        <h2>Is Your Data on the Dark Web?</h2>
      </div>
      <div class="exit-popup-body">
        <h3>Get Your FREE Dark Web Scan</h3>
        <p>Cybercriminals trade stolen business data on the dark web every day. Your company's passwords, client information, and financial data could be exposed right now – and you wouldn't even know it.</p>
        <div class="exit-popup-features">
          <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ayvant-red)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg> No Strings Attached</span>
          <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ayvant-red)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg> No Obligation</span>
          <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ayvant-red)" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Results in 48 Hours</span>
        </div>
        <div class="exit-popup-callout">
          <strong style="color: var(--ayvant-red);">Perfect for Law Firms & Accountants:</strong> Your clients trust you with their most sensitive information. Find out if that trust has been compromised.
        </div>
        <!-- Iframe loads only when popup is shown (see main.js) -->
        <div id="exit-popup-form-container" data-form-url="{{ site.ghlDarkWebForm }}" style="width: 100%; height: 600px;"></div>
      </div>
    </div>
  </div>

  <!-- Main JavaScript (critical for cookie/popup functionality) -->
  <script src="/js/main.js"></script>
  
  <!-- Google Analytics - Deferred to not block rendering -->
  <script defer src="https://www.googletagmanager.com/gtag/js?id=G-2B3N9Z8CCH"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-2B3N9Z8CCH');
  </script>

<!-- GHL Chat Widget - Desktop only (disabled on mobile for performance) -->
  <script>
    if (window.innerWidth >= 768) {
      var chatScript = document.createElement('script');
      chatScript.src = 'https://beta.leadconnectorhq.com/loader.js';
      chatScript.defer = true;
      chatScript.setAttribute('data-resources-url', 'https://beta.leadconnectorhq.com/chat-widget/loader.js');
      chatScript.setAttribute('data-widget-id', '{{ site.ghlChatWidgetId }}');
      document.body.appendChild(chatScript);
    }
  </script>
  
  <!-- GHL Form Embed Script - Deferred -->
  <script defer src="https://link.msgsndr.com/js/form_embed.js"></script>
</body>
</html>
